{
  "name": "example",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "detox:build:android": "detox build --configuration android.emu.debug",
    "detox:test:android": "detox test --configuration android.emu.debug",
    "detox:build:android:release": "detox build --configuration android.emu.release",
    "detox:test:android:release": "detox test --configuration android.emu.release"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-geckoview": "file:../"
  },
  "devDependencies": {
    "@babel/core": "^7.8.3",
    "@react-native-community/cli": "latest",
    "@react-native-community/eslint-config": "^0.0.6",
    "@react-native/babel-preset": "^0.81.0",
    "@react-native/metro-config": "^0.81.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.8.1",
    "@types/jest": "^29.0.0",
    "@types/react": "^19.0.0",
    "@types/react-test-renderer": "^18.0.0",
    "@types/detox": "^18.1.0",
    "babel-jest": "^29.0.0",
    "detox": "20.44.0",
    "eslint": "^6.8.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "metro-react-native-babel-preset": "^0.58.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "react-native",
    "roots": [
      "<rootDir>",
      "<rootDir>/.."
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "testUtils.ts",
      "<rootDir>/e2e/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native-geckoview)/)"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/node_modules/react-native"
    },
    "collectCoverageFrom": [
      "node_modules/react-native-geckoview/src/**/*.{js,jsx,ts,tsx}",
      "node_modules/react-native-geckoview/index.tsx",
      "../src/**/*.{js,jsx,ts,tsx}",
      "../index.tsx",
      "!../src/**/*.d.ts",
      "!../node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "coverageReporters": [
      "html",
      "text",
      "lcov",
      "json-summary"
    ],
    "coverageDirectory": "<rootDir>/coverage"
  }
}